datasource db {
  provider = "sqlite"
  url      = "file:dev.db"
}

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

model User {
  id                String    @id @default(uuid())
  firebaseUid       String?   @unique
  email             String    @unique
  password          String?
  name              String
  phone             String?
  role              String    @default("customer") // "admin", "company", "employee", "customer"
  pincode           String?
  district          String?
  state             String?
  budgetRange       String?
  purpose           String?
  gstNumber         String?
  businessMail      String?
  keyId             String?
  position          String?
  companyCode       String?
  companyId         String?
  company           User?     @relation("CompanyEmployees", fields: [companyId], references: [id])
  employees         User[]    @relation("CompanyEmployees")
  permissions       String?   @default("{}")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  // New fields for company management
  address           String?
  status            String?   @default("active") // "active", "inactive", "restricted"
  lastLogin         DateTime?
  lastActivity      DateTime?

  // New fields for subscription management
  subscriptionStatus    String?   @default("inactive") // "active", "inactive", "expired"
  subscriptionStartDate DateTime?
  subscriptionExpiryDate DateTime?

  // Relations
  createdProjects   Project[] @relation("CreatedProjects")
  assignedProjects  Project[] @relation("AssignedProjects")
  customerProjects  Project[] @relation("CustomerProjects")
  createdQuotes     Quote[]   @relation("CreatedQuotes")
  customerQuotes    Quote[]   @relation("CustomerQuotes")
}

model Project {
  id          String    @id @default(uuid())
  name        String
  companyId   String
  company     User      @relation("CreatedProjects", fields: [companyId], references: [id])
  customerId  String
  customer    User      @relation("CustomerProjects", fields: [customerId], references: [id])
  assignedEmployees User[] @relation("AssignedProjects")
  status      String    @default("ongoing") // "ongoing", "completed", "on-hold"
  budget      Float?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  quotes      Quote[]
}

model Quote {
  id              String    @id @default(uuid())
  quoteNumber     String    @unique
  companyId       String
  company         User      @relation(fields: [companyId], references: [id])
  projectId       String
  project         Project   @relation(fields: [projectId], references: [id])
  customerId      String
  customer        User      @relation("CustomerQuotes", fields: [customerId], references: [id])
  employeeId      String
  employee        User      @relation("CreatedQuotes", fields: [employeeId], references: [id])
  calculatorUsed  String
  amount          Float
  status          String    @default("draft") // "draft", "sent", "accepted", "rejected"
  createdAt       DateTime  @default(now())
  productsJson    String   @default("[]")
  woodworkJson    String   @default("[]")
  doorJson        String   @default("[]")
}

model Brand {
  id      String  @id @default(uuid())
  name    String
  logoUrl String?
}

model Category {
  id            String  @id @default(uuid())
  name          String
  description   String?
  subcategories String  @default("[]")
}

model Product {
  id           String   @id
  calculator   String
  categoryId   String
  subcategory  String   @default("No Subcategory")
  name         String
  description  String?
  imageUrl     String?
  unit         String
  rate         Float
  variants     String   @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model WoodworkItem {
  id          String   @id @default(uuid())
  name        String
  description String?
  options     String   @default("[]")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DoorTemplate {
  id          String        @id @default(uuid())
  name        String
  description String?
  imageUrl    String?
  icon        String        @default("🚪")
  isPublished Boolean       @default(true)
  sortOrder   Int           @default(0)
  variants    DoorVariant[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model DoorVariant {
  id          String       @id @default(uuid())
  templateId  String
  template    DoorTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  name        String
  description String?
  basePrice   Float
  imageUrl    String?
  sku         String?
  isActive    Boolean      @default(true)
  sortOrder   Int          @default(0)
  finishes    DoorFinish[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model DoorFinish {
  id          String      @id @default(uuid())
  variantId   String
  variant     DoorVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  priceType   String      @default("absolute")
  priceValue  Float
  imageUrl    String?
  isActive    Boolean     @default(true)
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model DoorAddonGroup {
  id                 String      @id @default(uuid())
  name               String
  description        String?
  selectionType      String      @default("multiple")
  isRequired         Boolean     @default(false)
  appliesToTemplates String      @default("[]")
  sortOrder          Int         @default(0)
  addons             DoorAddon[]
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
}

model DoorAddon {
  id          String         @id @default(uuid())
  groupId     String
  group       DoorAddonGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Float
  icon        String         @default("🔧")
  imageUrl    String?
  isActive    Boolean        @default(true)
  sortOrder   Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model DoorSetting {
  id                  String   @id @default("global")
  taxPercent          Float    @default(18.0)
  installationCharges Float    @default(0.0)
  installationType    String   @default("fixed")
  minQuantity         Int      @default(1)
  maxQuantity         Int      @default(100)
  whatsappNumber      String   @default("")
  floorOptions        String   @default("[]")
  areaOptions         String   @default("[]")
  updatedAt           DateTime @updatedAt
}
